{
  "name": "techvalley-backend",
  "private": true,
  "version": "1.0.0",
  "description": "Techvalley IoT API — NestJS (03.source/beckend)",
  "scripts": {
    "build": "nest build",
    "check": "npm run build && npm run test:unit",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest --config test/jest-unit.json --runInBand",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand",
    "test:local": "bash test/run-e2e-local.sh"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1068.0",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/typeorm": "^11.0.0",
    "aws-jwt-verify": "^5.2.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "mongodb": "^6.21.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.24",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.26",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.30",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
