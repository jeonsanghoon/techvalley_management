# Backend API
PORT=3002

# ─── Auth ───────────────────────────────────────────────────────────────────
# local: 자체 JWT (bcrypt) | aws: Amazon Cognito
AUTH_PROVIDER=local
AUTH_ENABLED=true
JWT_SECRET=techvalley-dev-jwt-secret-change-me
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
# password_hash 없을 때 userId+demo-password 허용 (로컬 개발)
AUTH_ALLOW_DEMO_LOGIN=true

# AWS Cognito (AUTH_PROVIDER=aws 일 때 필수)
# COGNITO_REGION=ap-northeast-2
# COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXXX
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Postgres / Mongo — npm run local:up 기준
# TV_POSTGRES_URI=postgresql://tv:tv_local_dev@127.0.0.1:35432/iot_analytics
# TV_MONGO_URI=mongodb://tv:tv_local_dev@127.0.0.1:37017/iot_service?authSource=admin
