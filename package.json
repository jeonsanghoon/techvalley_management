{
  "name": "techvalley_management",
  "version": "1.0.0",
  "private": true,
  "description": "Techvalley IoT management monorepo (00.doc · 02.arch · 03.source · 10.local · 90.infra)",
  "scripts": {
    "dev:frontend": "npm run dev --prefix 03.source/frontend",
    "build:frontend": "npm run build --prefix 03.source/frontend",
    "build:architecture-docs": "npm run build --prefix 00.doc/architecture/site",
    "build:architecture-legacy": "npm run build:legacy-html --prefix 00.doc/architecture",
    "dev:architecture-docs": "npm run dev --prefix 00.doc/architecture/site",
    "local:up": "bash 90.infra/10.local/local-up.sh",
    "local:status": "bash 90.infra/10.local/local-status.sh",
    "local:verify": "bash 90.infra/10.local/local-verify.sh",
    "local:test": "bash 90.infra/10.local/local-test-all.sh",
    "local:e2e": "bash 90.infra/10.local/local-e2e-full.sh",
    "local:down": "bash 90.infra/10.local/local-down.sh",
    "test:backend": "npm run test:local --prefix 03.source/beckend",
    "dev:backend": "npm run dev --prefix 03.source/beckend",
    "start:backend": "npm run start --prefix 03.source/beckend",
    "lint:frontend": "npm run lint --prefix 03.source/frontend",
    "start:frontend": "npm run start --prefix 03.source/frontend"
  },
