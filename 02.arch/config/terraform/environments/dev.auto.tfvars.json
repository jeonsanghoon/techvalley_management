{
  "_comment": "npm run tfvars 로 생성 — 수동 편집 금지 (테크밸리 deploy-ssot)",
  "project_name": "tv-ingress",
  "environment": "dev",
  "aws_region": "ap-northeast-2",
  "tags": {
    "Project": "techvalley",
    "ManagedBy": "terraform"
  },
  "partition_key_field": "device_code",
  "iot": {
    "enabled": true,
    "sql_version": "2016-03-23",
    "partition_key_expression": "${device_code}",
    "default_stream_key": "ingest_main",
    "default_tenant": "tv"
  },
  "analytics_lake": {
    "enabled": true,
    "lake_config_ref": "02.arch/config/schema/iceberg/lake-config.yaml",
    "s3": {
      "bucket_suffix": "tv-analytics-raw",
      "force_destroy": false,
      "landing_prefix": "cold-stream-events/",
      "dynamic_prefix": "cold-stream-events/year=!{timestamp:yyyy}/month=!{timestamp:MM}/day=!{timestamp:dd}/",
      "errors_prefix": "errors/firehose/cold-stream-events/",
      "iceberg_warehouse_prefix": "iceberg/warehouse/",
      "media_prefix": "media/",
      "media_upload_bucket_suffix": "tv-media-upload",
      "lifecycle_landing_days": 7,
      "lifecycle_errors_days": 30
    },
    "firehose": {
      "stream_suffix": "cold-stream-events",
      "destination": "extended_s3",
      "buffer_interval_seconds": 900,
      "buffer_size_mb": 128,
      "parquet_compression": "SNAPPY"
    },
    "glue": {
      "database_name": "techvalley_analytics",
      "default_table_id": "stream_fact_telemetry",
      "table_name": "stream_fact_telemetry"
    },
    "name_prefix": "tv-ingress-dev",
    "s3_bucket": "tv-ingress-dev-tv-analytics-raw",
    "firehose_stream_name": "tv-ingress-dev-cold-stream-events",
    "glue_database_name": "techvalley_analytics"
  },
  "data_plane": {
    "enabled": false,
    "documentdb": {
      "cluster_identifier_suffix": "tv-doc",
      "database_name": "iot_service",
      "ssm_parameter_prefix": "/techvalley/dev/documentdb"
    },
    "rds": {
      "ssm_parameter_prefix": "/techvalley/dev/rds"
    },
    "secrets": {
      "create_placeholders": true
    }
  },
  "lambda_iam_roles": {
    "kds_consumer": {
      "description": "stream-sync-consumer — KDS read, Firehose Put (analytics enabled 시)",
      "statements": [
        {
          "Effect": "Allow",
          "Action": [
            "kinesis:DescribeStream",
            "kinesis:GetRecords",
            "kinesis:GetShardIterator",
            "kinesis:ListShards",
            "kinesis:ListStreams"
          ],
          "Resource": "*"
        },
        {
          "Effect": "Allow",
          "Action": [
            "firehose:PutRecord",
            "firehose:PutRecordBatch"
          ],
          "Resource": "*"
        }
      ]
    },
    "kinesis_esm_dlq": {
      "description": "dlq-shard-processor — SQS from Kinesis failure destination",
      "statements": [
        {
          "Effect": "Allow",
          "Action": [
            "sqs:ReceiveMessage",
            "sqs:DeleteMessage",
            "sqs:GetQueueAttributes"
          ],
          "Resource": "*"
        }
      ]
    },
    "cadence_executor": {
      "description": "batch-cadence-runner — DocumentDB read/write, Aurora",
      "statements": [
        {
          "Effect": "Allow",
          "Action": [
            "secretsmanager:GetSecretValue"
          ],
          "Resource": "*"
        }
      ]
    },
    "batch_dlq_replay": {
      "description": "batch-dlq-replay — Doc DLQ + invoke runner",
      "statements": [
        {
          "Effect": "Allow",
          "Action": [
            "secretsmanager:GetSecretValue"
          ],
          "Resource": "*"
        }
      ]
    },
    "payload_convert": {
      "description": "payload-converter — rules bundle only",
      "statements": []
    },
    "sagemaker_invoke": {
      "description": "anomaly-scorer — SageMaker Endpoint invoke",
      "statements": [
        {
          "Effect": "Allow",
          "Action": [
            "sagemaker:InvokeEndpoint"
          ],
          "Resource": "*"
        }
      ]
    },
    "rule_recommender": {
      "description": "rule-recommender — Aurora write, optional Bedrock read",
      "statements": [
        {
          "Effect": "Allow",
          "Action": [
            "secretsmanager:GetSecretValue"
          ],
          "Resource": "*"
        }
      ]
    },
    "self_heal": {
      "description": "self-heal-orchestrator — IoT Jobs create, Shadow update",
      "statements": [
        {
          "Effect": "Allow",
          "Action": [
            "iot:CreateJob",
            "iot:UpdateThingShadow"
          ],
          "Resource": "*"
        }
      ]
    },
    "media_upload_orchestrator": {
      "description": "file-upload-orchestrator — S3 presign, multipart, IoT publish response",
      "statements": [
        {
          "Effect": "Allow",
          "Action": [
            "s3:PutObject",
            "s3:GetObject",
            "s3:AbortMultipartUpload",
            "s3:ListMultipartUploadParts",
            "s3:CreateMultipartUpload",
            "s3:CompleteMultipartUpload",
            "s3:UploadPart"
          ],
          "Resource": "*"
        },
        {
          "Effect": "Allow",
          "Action": [
            "iot:Publish"
          ],
          "Resource": "*"
        },
        {
          "Effect": "Allow",
          "Action": [
            "secretsmanager:GetSecretValue"
          ],
          "Resource": "*"
        }
      ]
    }
  },
  "lambdas": {
    "stream_sync_consumer": {
      "deploy_group": "ingress",
      "role": "kds_consumer",
      "runtime": "nodejs24.x",
      "architecture": "arm64",
      "memory_mb": 512,
      "timeout_seconds": 60,
      "handler": "lambda.handler",
      "source_dir": "03.source/lambda/apps/stream-sync-consumer/bundle",
      "environment": {
        "PARTITION_KEY_FIELD": "device_code",
        "RULES_DIR": "/var/task/rules",
        "NORMALIZE_CONFIG_PATH": "/var/task/config/normalize-config.default.yaml",
        "FIREHOSE_STREAM_NAME": "tv-ingress-dev-cold-stream-events",
        "FIREHOSE_DISABLED": "false"
      }
    },
    "dlq_shard_processor": {
      "deploy_group": "ingress",
      "role": "kinesis_esm_dlq",
      "runtime": "nodejs24.x",
      "architecture": "arm64",
      "memory_mb": 256,
      "timeout_seconds": 120,
      "handler": "lambda.handler",
      "source_dir": "03.source/lambda/apps/dlq-shard-processor/bundle",
      "environment": {
        "PARTITION_KEY_FIELD": "device_code",
        "DLQ_GROUP_BY": "shard_key"
      }
    },
    "batch_cadence_runner": {
      "deploy_group": "batch",
      "role": "cadence_executor",
      "runtime": "nodejs24.x",
      "architecture": "arm64",
      "memory_mb": 1024,
      "timeout_seconds": 900,
      "handler": "lambda.handler",
      "source_dir": "03.source/lambda/apps/batch-cadence-runner/bundle",
      "environment": {
        "TV_BATCH_SCHEDULER": "eventbridge",
        "BATCH_CADENCE_CONFIG_PATH": "/var/task/config/02-batch-cadence.yaml",
        "BATCH_DLQ_COLLECTION": "pipeline_dlq_events",
        "DEVICE_CODE_FIELD": "device_code"
      }
    },
    "batch_dlq_replay": {
      "deploy_group": "batch",
      "role": "batch_dlq_replay",
      "runtime": "nodejs24.x",
      "architecture": "arm64",
      "memory_mb": 512,
      "timeout_seconds": 300,
      "handler": "lambda.handler",
      "source_dir": "03.source/lambda/apps/batch-dlq-replay/bundle",
      "environment": {
        "TV_BATCH_SCHEDULER": "eventbridge",
        "BATCH_DLQ_COLLECTION": "pipeline_dlq_events",
        "REPLAY_MODE": "invoke_original_lambda",
        "GROUP_BY_FIELD": "cadence_id"
      }
    },
    "payload_converter": {
      "deploy_group": "invoke_only",
      "role": "payload_convert",
      "runtime": "nodejs24.x",
      "architecture": "arm64",
      "memory_mb": 512,
      "timeout_seconds": 60,
      "handler": "lambda.handler",
      "source_dir": "03.source/lambda/apps/payload-converter/bundle",
      "environment": {
        "RULES_DIR": "/var/task/rules"
      }
    },
    "file_upload_orchestrator": {
      "deploy_group": "ingress",
      "role": "media_upload_orchestrator",
      "runtime": "nodejs24.x",
      "architecture": "arm64",
      "memory_mb": 512,
      "timeout_seconds": 120,
      "handler": "lambda.handler",
      "source_dir": "03.source/lambda/apps/file-upload-orchestrator/bundle",
      "environment": {
        "TV_MEDIA_BUCKET": "tv-ingress-dev-tv-media-upload",
        "MEDIA_UPLOAD_CONFIG_PATH": "/var/task/config/media-upload.yaml",
        "IOT_RESPONSE_TOPIC_TEMPLATE": "tv/{env}/{edge}/{device_code}/event/file/response/json",
        "PARTITION_KEY_FIELD": "device_code"
      }
    },
    "anomaly_scorer": {
      "deploy_group": "ml",
      "role": "sagemaker_invoke",
      "runtime": "nodejs24.x",
      "architecture": "arm64",
      "memory_mb": 512,
      "timeout_seconds": 120,
      "handler": "lambda.handler",
      "source_dir": "03.source/lambda/apps/anomaly-scorer/bundle",
      "environment": {
        "SAGEMAKER_ENDPOINT_NAME": "tv-tube-multivariate-v3",
        "ANOMALY_EVENTS_TABLE": "anomaly_events"
      }
    },
    "rule_recommender": {
      "deploy_group": "ml",
      "role": "rule_recommender",
      "runtime": "nodejs24.x",
      "architecture": "arm64",
      "memory_mb": 512,
      "timeout_seconds": 60,
      "handler": "lambda.handler",
      "source_dir": "03.source/lambda/apps/rule-recommender/bundle",
      "environment": {
        "RULE_RECOMMENDATIONS_TABLE": "rule_recommendations"
      }
    },
    "self_heal_orchestrator": {
      "deploy_group": "ml",
      "role": "self_heal",
      "runtime": "nodejs24.x",
      "architecture": "arm64",
      "memory_mb": 512,
      "timeout_seconds": 300,
      "handler": "lambda.handler",
      "source_dir": "03.source/lambda/apps/self-heal-orchestrator/bundle",
      "environment": {
        "SELF_HEAL_PLAYBOOKS_TABLE": "self_heal_playbooks"
      }
    }
  },
  "streams": {
    "ingest_main": {
      "manifest_stream_id": "ingest_main",
      "kinesis": {
        "stream_mode": "ON_DEMAND",
        "shard_count": 8,
        "retention_hours": 168
      },
      "consumer": {
        "lambda_ref": "stream_sync_consumer",
        "batch_size": 100,
        "maximum_batching_window_in_seconds": 5,
        "parallelization_factor": 1,
        "starting_position": "LATEST",
        "bisect_batch_on_function_error": true,
        "report_batch_item_failures": true,
        "maximum_retry_attempts": 3,
        "maximum_record_age_in_seconds": 604800
      },
      "dlq": {
        "enabled": true,
        "sqs_queue_key": "ingest_main_dlq",
        "message_retention_seconds": 1209600,
        "visibility_timeout_seconds": 300,
        "processor": {
          "lambda_ref": "dlq_shard_processor",
          "batch_size": 10,
          "maximum_batching_window_in_seconds": 10,
          "routing": {
            "partition_key_field": "device_code",
            "group_by": "shard_key"
          }
        }
      }
    }
  },
  "batch_schedules": [
    {
      "schedule_key": "rollup_device_10min",
      "cadence_id": "rollup_device_10min",
      "kind": "telemetry_rollup",
      "schedule_expression": "cron(0/10 * * * ? *)"
    },
    {
      "schedule_key": "communication_quality_eval_10m",
      "cadence_id": "communication_quality_eval_10m",
      "kind": "communication_quality_eval",
      "schedule_expression": "cron(30/10 * * * ? *)"
    },
    {
      "schedule_key": "rollup_hourly",
      "cadence_id": "rollup_hourly",
      "kind": "telemetry_rollup",
      "schedule_expression": "cron(0 * * * ? *)"
    },
    {
      "schedule_key": "rollup_daily",
      "cadence_id": "rollup_daily",
      "kind": "telemetry_rollup",
      "schedule_expression": "cron(5 0 * * ? *)"
    },
    {
      "schedule_key": "rollup_monthly",
      "cadence_id": "rollup_monthly",
      "kind": "telemetry_rollup",
      "schedule_expression": "cron(0 2 1 * ? *)"
    },
    {
      "schedule_key": "fleet_hourly_export",
      "cadence_id": "fleet_hourly_export",
      "kind": "aurora_rollup",
      "schedule_expression": "cron(15 * * * ? *)"
    }
  ],
  "ml_triggers": [
    {
      "schedule_key": "anomaly_batch_scoring",
      "lambda_ref": "anomaly_scorer",
      "enabled": true,
      "schedule_expression": "rate(5 minutes)"
    },
    {
      "event_pattern": "tv.anomaly.detected",
      "lambda_ref": "rule_recommender",
      "enabled": true
    },
    {
      "event_pattern": "tv.anomaly.detected",
      "lambda_ref": "self_heal_orchestrator",
      "enabled": true,
      "filter": {
        "root_cause_hint": "edge_client",
        "min_confidence": 0.9
      }
    }
  ],
  "batch_runner_lambda": "batch_cadence_runner"
}