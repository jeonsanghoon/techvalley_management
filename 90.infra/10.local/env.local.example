# 로컬 env — source 후 export (SSOT: lib/ports.sh)
# cp env.local.example env.local && set -a && source env.local && set +a
#
# 포트는 mobi(25432), fota(5433/27018/9090), cesco(3306/27017) 등과 충돌하지 않는 TV 전용 대역

TV_POSTGRES_PORT=35432
TV_MONGO_PORT=37017
TV_MINIO_API_PORT=39100
TV_MINIO_CONSOLE_PORT=39101

TV_MONGO_URI=mongodb://tv:tv_local_dev@127.0.0.1:37017/iot_service?authSource=admin&directConnection=true
TV_POSTGRES_URI=postgresql://tv:tv_local_dev@127.0.0.1:35432/iot_analytics

PGHOST=127.0.0.1
PGPORT=35432
PGUSER=tv
PGPASSWORD=tv_local_dev
PGDATABASE=iot_analytics

MONGO_URI=mongodb://tv:tv_local_dev@127.0.0.1:37017/iot_service?authSource=admin&directConnection=true

MINIO_ENDPOINT=http://127.0.0.1:39100
MINIO_CONSOLE=http://127.0.0.1:39101
MINIO_ROOT_USER=tv
MINIO_ROOT_PASSWORD=tv_local_dev
MINIO_BUCKET=tv-analytics-raw
MINIO_MEDIA_BUCKET=tv-media-upload

# Lambda S3 SDK (file-upload-orchestrator — next)
AWS_ENDPOINT_URL=http://127.0.0.1:39100
AWS_ACCESS_KEY_ID=tv
AWS_SECRET_ACCESS_KEY=tv_local_dev
AWS_REGION=ap-northeast-2
S3_FORCE_PATH_STYLE=true

# Frontend (optional — E2E with beckend)
# NEXT_PUBLIC_API_URL=http://localhost:3002/api
