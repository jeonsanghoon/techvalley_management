{
  "rule_id": "rule_file_abort_v1",
  "rule_code": "rule_file_abort_v1",
  "rule_version": "1.0.0",
  "spec_version": "1",
  "deploy_version": "1.0.0",
  "description": "event/file/abort — 업로드 중단",
  "topic_match": [
    {
      "pattern": "tv/{env}/+/+/event/file/abort/json"
    }
  ],
  "payload": {
    "type": "json_to_json",
    "format": {
      "strict": false,
      "max_depth": 24
    },
    "map": [
      {
        "from": "deviceId",
        "to": "device_code",
        "target_type": "string",
        "required": true
      },
      {
        "from": "request_code",
        "to": "request_code",
        "target_type": "string",
        "required": true
      },
      {
        "from": "upload_id",
        "to": "upload_id",
        "target_type": "string",
        "required": false
      },
      {
        "from": "reason",
        "to": "abort_reason",
        "target_type": "string",
        "required": false
      },
      {
        "from": "device_timestamp",
        "to": "device_timestamp",
        "target_type": "int64",
        "required": true
      },
      {
        "from": "file_transfer_status",
        "to": "file_transfer_status",
        "target_type": "string",
        "required": false,
        "default": "ABORTED"
      }
    ],
    "target": {
      "document_model": "flat_json"
    }
  },
  "targets": [
    {
      "collection": "files_history",
      "unique_key": [
        "device_code",
        "request_code",
        "device_timestamp",
        "data_index"
      ],
      "on_duplicate": "update"
    }
  ]
}